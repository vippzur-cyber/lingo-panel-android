<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_bg"
    android:padding="14dp"
    android:animateLayoutChanges="true">

    <!-- Header (drag handle) -->
    <LinearLayout
        android:id="@+id/panelHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LINGO PANEL"
            android:textColor="@color/text_light"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/text_muted"
            android:textSize="16sp"
            android:padding="4dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Tabs (scroll horizontal biar muat banyak tab) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/tabTranslate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="TRANSLATE"
            android:textSize="10sp"
            android:backgroundTint="@color/rose"
            android:textColor="@color/text_light" />

        <Button
            android:id="@+id/tabBooster"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="6dp"
            android:text="FPS BOOSTER"
            android:textSize="10sp"
            android:backgroundTint="@color/panel_dark"
            android:textColor="@color/text_muted" />

        <Button
            android:id="@+id/tabTools"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="6dp"
            android:text="TOOLS"
            android:textSize="10sp"
            android:backgroundTint="@color/panel_dark"
            android:textColor="@color/text_muted" />

        <Button
            android:id="@+id/tabSystem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="6dp"
            android:text="SYSTEM"
            android:textSize="10sp"
            android:backgroundTint="@color/panel_dark"
            android:textColor="@color/text_muted" />

    </LinearLayout>
    </HorizontalScrollView>

    <!-- Konten tab: masing-masing section dikasih minHeight yang sama (lihat sectionTranslate & sectionBooster)
         biar ukuran panel selalu konsisten pas ganti tab, tanpa nyisain area kosong -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="vertical"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

    <!-- Translate section -->
    <LinearLayout
        android:id="@+id/sectionTranslate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="330dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <AutoCompleteTextView
                android:id="@+id/acSource"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:hint="Cari bahasa..."
                android:inputType="text"
                android:background="@drawable/input_bg"
                android:padding="8dp"
                android:textColor="@color/text_light"
                android:textColorHint="@color/text_muted"
                android:textSize="12sp"
                android:completionThreshold="1" />

            <AutoCompleteTextView
                android:id="@+id/acTarget"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:hint="Cari bahasa..."
                android:inputType="text"
                android:background="@drawable/input_bg"
                android:padding="8dp"
                android:textColor="@color/text_light"
                android:textColorHint="@color/text_muted"
                android:textSize="12sp"
                android:completionThreshold="1" />
        </LinearLayout>

        <EditText
            android:id="@+id/etInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="4"
            android:gravity="top"
            android:background="@drawable/input_bg"
            android:padding="8dp"
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_muted"
            android:hint="Tulis teks di sini..."
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnTranslate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Terjemahkan"
                android:backgroundTint="@color/rose"
                android:textColor="@color/text_light" />

            <ProgressBar
                android:id="@+id/pbLoading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:visibility="gone"
                android:indeterminateTint="@color/rose" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvHasilLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hasil"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/btnCopy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salin"
                android:textColor="@color/rose"
                android:textSize="11sp"
                android:padding="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="90dp"
            android:background="@drawable/input_bg"
            android:padding="8dp"
            android:textColor="@color/text_light"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- FPS booster section -->
    <LinearLayout
        android:id="@+id/sectionBooster"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="330dp"
        android:orientation="vertical"
        android:visibility="gone">

        <CheckBox
            android:id="@+id/cbBg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tutup Aplikasi Background"
            android:textColor="@color/text_light"
            android:checked="true" />

        <CheckBox
            android:id="@+id/cbRam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bersihkan RAM"
            android:textColor="@color/text_light"
            android:checked="true" />

        <CheckBox
            android:id="@+id/cbNotif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bisukan Notifikasi"
            android:textColor="@color/text_light" />

        <Button
            android:id="@+id/btnBoost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jalankan Boost"
            android:backgroundTint="@color/rose"
            android:textColor="@color/text_light"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Boost ini beneran menutup proses background &amp; membersihkan cache aplikasi (butuh izin Akses Penggunaan sekali di awal). Tapi Android sudah cukup efisien mengatur memori sendiri, jadi efeknya ke FPS bisa kecil/tidak terasa."
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- Tools section: 5 utilitas ringan -->
    <LinearLayout
        android:id="@+id/sectionTools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="330dp"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Stopwatch -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STOPWATCH"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvStopwatch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00:00"
                android:textColor="@color/text_light"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnStopwatchToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mulai"
                android:textSize="10sp"
                android:backgroundTint="@color/rose"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnStopwatchReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_muted" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_line"
            android:layout_marginBottom="12dp" />

        <!-- Quick Notes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="QUICK NOTES"
                android:textColor="@color/rose"
                android:textStyle="bold"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btnEditNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✎"
                android:textColor="@color/text_light"
                android:textSize="15sp"
                android:padding="4dp" />

            <TextView
                android:id="@+id/btnSaveNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💾"
                android:textSize="15sp"
                android:padding="4dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top"
            android:background="@drawable/input_bg"
            android:padding="8dp"
            android:hint="Tap ikon pensil buat mulai nulis..."
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_muted"
            android:textSize="12sp"
            android:enabled="false"
            android:layout_marginBottom="10dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_line"
            android:layout_marginBottom="12dp" />

        <!-- Reminder -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REMINDER"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etReminderText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Isi pengingat..."
            android:background="@drawable/input_bg"
            android:padding="8dp"
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/etReminderMinutes"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="menit"
                android:inputType="number"
                android:background="@drawable/input_bg"
                android:padding="8dp"
                android:textColor="@color/text_light"
                android:textColorHint="@color/text_muted"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSetReminder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Pasang Reminder"
                android:textSize="10sp"
                android:backgroundTint="@color/rose"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_line"
            android:layout_marginBottom="12dp" />

        <!-- Clipboard Manager -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLIPBOARD MANAGER"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnClipboardSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Simpan dari Clipboard"
                android:textSize="10sp"
                android:backgroundTint="@color/rose"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnClipboardClear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Bersihkan"
                android:textSize="10sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_muted" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/clipboardList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>

    <!-- System section: info & kontrol sistem -->
    <LinearLayout
        android:id="@+id/sectionSystem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="330dp"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Baterai & RAM -->
        <TextView
            android:id="@+id/tvBatteryInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔋 Baterai: --%"
            android:textColor="@color/text_light"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvRamInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧠 RAM: --"
            android:textColor="@color/text_light"
            android:textSize="12sp"
            android:layout_marginBottom="10dp" />

        <!-- Volume -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔊 VOLUME MEDIA"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnVolDown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="－"
                android:textSize="12sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />

            <TextView
                android:id="@+id/tvVolLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="--"
                android:textColor="@color/text_light"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnVolUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋"
                android:textSize="12sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <!-- Brightness -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 BRIGHTNESS"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnBrightDown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="－"
                android:textSize="12sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />

            <TextView
                android:id="@+id/tvBrightLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="--"
                android:textColor="@color/text_light"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBrightUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋"
                android:textSize="12sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <!-- Toggle cepat: senter, DND, kunci orientasi -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TOGGLE CEPAT"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnFlashlight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔦 Senter"
                android:textSize="10sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnDnd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="🔇 DND"
                android:textSize="10sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnOrientationLock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="🔒 Kunci Rotasi"
                android:textSize="10sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <!-- Kontrol musik -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎵 KONTROL MUSIK"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnMusicPrev"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏮"
                android:textSize="12sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnMusicPlayPause"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="⏯"
                android:textSize="12sp"
                android:backgroundTint="@color/rose"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnMusicNext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="⏭"
                android:textSize="12sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <!-- Shortcut buka app lain -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎮 SHORTCUT APP"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOpenDiscord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Discord"
                android:textSize="10sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnOpenWhatsapp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="WhatsApp"
                android:textSize="10sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />

            <Button
                android:id="@+id/btnOpenBrowser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Browser"
                android:textSize="10sp"
                android:backgroundTint="@color/panel_dark"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INFO &amp; JARINGAN"
            android:textColor="@color/rose"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnToggleBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔋 Baterai %"
            android:textSize="11sp"
            android:backgroundTint="@color/panel_dark"
